# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configurations
MONGO_URI=mongodb://localhost:27017/multi-grocery-store

# Redis Configurations
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication Secrets
JWT_SECRET=grocery_secret_key_session_token_98765
JWT_REFRESH_SECRET=grocery_refresh_token_secret_key_98765
JWT_EXPIRE=1d
JWT_REFRESH_EXPIRE=7d

# File Storage Configuration (local or s3)
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=your_s3_bucket_name
AWS_S3_REGION=ap-south-1

# UPI Payment simulator
UPI_VPA=merchant@ybl
UPI_MERCHANT_NAME=SmartGrocerySaaS
